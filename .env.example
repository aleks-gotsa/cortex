# ── API Keys ──────────────────────────────────────
ANTHROPIC_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=

# ── Vector Memory (Qdrant) ────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cortex_research
QDRANT_API_KEY=

# ── Storage ───────────────────────────────────────
DATABASE_PATH=./data/cortex.db

# ── Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Cortex-D: Dynamo Disaggregated Inference ──────
# Set DYNAMO_ENABLED=true to route through Dynamo workers
DYNAMO_ENABLED=false
DYNAMO_MODE=mock
DYNAMO_PREFILL_URL=http://localhost:8001/v1
DYNAMO_DECODE_URL=http://localhost:8002/v1
DYNAMO_TRITON_URL=http://localhost:8003
DYNAMO_PREFILL_MODEL=meta-llama/Llama-3.1-8B-Instruct
DYNAMO_DECODE_MODEL=meta-llama/Llama-3.1-70B-Instruct
DYNAMO_KVCACHE_ENABLED=false
