# ── API Keys ──────────────────────────────────────
ANTHROPIC_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=

# ── Local backend ─────────────────────────────────
# LLM_BACKEND=local routes every pipeline LLM call to an OpenAI-compatible
# endpoint (Ollama is the tested case) — no Anthropic key needed.
# Search still uses Serper. Each pipeline stage maps to its LOCAL_MODEL_* tag.
LLM_BACKEND=anthropic            # anthropic | local
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_PLANNING=llama3.2:3b
LOCAL_MODEL_GAP_DETECTION=llama3.2:3b
# Synthesis/verification default to qwen2.5:7b-instruct: the reasoning-style
# qwen3:8b runs to the token cap when asked to regenerate a whole document as
# one JSON object (the verifier's contract), producing truncated/invalid JSON.
LOCAL_MODEL_SYNTHESIS=qwen2.5:7b-instruct
LOCAL_MODEL_VERIFICATION=qwen2.5:7b-instruct

# ── Vector Memory (Qdrant) ────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cortex_research
QDRANT_API_KEY=

# ── Storage ───────────────────────────────────────
DATABASE_PATH=./data/cortex.db

# ── Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Cortex-D: Dynamo Disaggregated Inference ──────
# Set DYNAMO_ENABLED=true to route through Dynamo workers
DYNAMO_ENABLED=false
DYNAMO_MODE=mock
DYNAMO_PREFILL_URL=http://localhost:8001/v1
DYNAMO_DECODE_URL=http://localhost:8002/v1
DYNAMO_TRITON_URL=http://localhost:8003
DYNAMO_PREFILL_MODEL=meta-llama/Llama-3.1-8B-Instruct
DYNAMO_DECODE_MODEL=meta-llama/Llama-3.1-70B-Instruct
DYNAMO_KVCACHE_ENABLED=false
