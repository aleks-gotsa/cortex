name: "bge-embeddings"
backend: "python"
max_batch_size: 32
input [{
  name: "TEXT"
  data_type: TYPE_BYTES
  dims: [1]
}]
output [{
  name: "EMBEDDINGS"
  data_type: TYPE_FP32
  dims: [384]
}]
dynamic_batching {
  preferred_batch_size: [8, 16, 32]
  max_queue_delay_microseconds: 5000
}
instance_group [{
  count: 1
  kind: KIND_GPU
}]
